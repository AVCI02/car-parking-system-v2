# نسخ الملف إلى .env محليًا أو ضبط المتغيرات في لوحة Railway.

# إلزامي على Railway عند ربط PostgreSQL (يُحقن تلقائيًا غالبًا).
# محليًا: اتركه فارغًا لاستخدام SQLite (ملف parking.db).
# على الاستضافة: عيّن SQLITE_DB_PATH لمسار دائم (volume) حتى لا تُفقد البيانات عند إعادة النشر.
# مثال: SQLITE_DB_PATH=/data/parking.db
# انظر DEPLOY.md لخطوات Railway والاستخدام اليومي.

DATABASE_URL=
SQLITE_DB_PATH=

# الرابط العام للموقع (بدون شرطة نهائية) ليُبنى QR بروفايل السيارة بشكل صحيح خلف Reverse Proxy أو Railway.
PARKING_PUBLIC_BASE_URL=

# مفتاح توقيع JWT — عيّن قيمة عشوائية طويلة في الإنتاج.
PARKING_JWT_SECRET=

# كلمات المرور الافتراضية عند أول تشغيل (قبل وجود مستخدمين في القاعدة).
PARKING_ADMIN_PASSWORD=
PARKING_EMPLOYEE_PASSWORD=

# مدة صلاحية الرمز بالساعات (اختياري، الافتراضي 12).
PARKING_JWT_HOURS=12

# المنفذ محليًا (Railway يضبط PORT تلقائيًا).
PORT=8000
